QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
RAG_COLLECTION=documents

RAG_EMBEDDING_MODEL=Octen/Octen-Embedding-0.6B
RAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RAG_GENERATION_MODEL=QuantTrio/Qwen3.5-9B-AWQ
RAG_VLLM_BASE_URL=http://vllm:8000/v1
RAG_VLLM_API_KEY=
RAG_VLLM_TIMEOUT=120
RAG_TRUST_REMOTE_CODE=true
RAG_ENABLE_RERANKER=true

RAG_HF_OFFLINE=0
RAG_TEMPERATURE=0.3
RAG_THINKING=false
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_EMBEDDING_BATCH_SIZE=32
RAG_TOP_K=5
RAG_CANDIDATE_K=25
RAG_VECTOR_WEIGHT=0.6
RAG_BM25_WEIGHT=0.4
RAG_RANK_CONSTANT=10
RAG_MAX_NEW_TOKENS=1024

# Пустое значение использует RAG_GENERATION_MODEL на том же vLLM endpoint.
RAGAS_JUDGE_MODEL=
RAGAS_THRESHOLD=0.7
RAGAS_MAX_TOKENS=2048
