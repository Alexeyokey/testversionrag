QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
RAG_COLLECTION=documents
# Работает только с образом qdrant:gpu-nvidia и ускоряет построение HNSW.
QDRANT_GPU_INDEXING=1
QDRANT_GPU_DEVICE_FILTER=nvidia

RAG_EMBEDDING_MODEL=Octen/Octen-Embedding-0.6B
RAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RAG_GENERATION_MODEL=QuantTrio/Qwen3.6-27B-AWQ
RAG_VLLM_BASE_URL=http://vllm:8000/v1
RAG_VLLM_API_KEY=
RAG_VLLM_TIMEOUT=300
RAG_VLLM_MAX_MODEL_LEN=8192
RAG_VLLM_MAX_NUM_SEQS=4
RAG_VLLM_MAX_CUDAGRAPH_CAPTURE_SIZE=4
RAG_VLLM_GPU_MEMORY_UTILIZATION=0.9
# Должно совпадать с количеством GPU, между которыми распределяется модель.
RAG_VLLM_TENSOR_PARALLEL_SIZE=1
RAG_TRUST_REMOTE_CODE=true
RAG_ENABLE_RERANKER=true

RAG_HF_OFFLINE=0
RAG_TEMPERATURE=0.3
RAG_THINKING=false
RAG_CHUNK_SIZE=1024
RAG_CHUNK_OVERLAP=50
RAG_DOCLING_CHUNK_TOKENS=1024
RAG_EMBEDDING_BATCH_SIZE=32
RAG_TOP_K=5
RAG_CANDIDATE_K=25
RAG_VECTOR_WEIGHT=0.6
RAG_BM25_WEIGHT=0.4
RAG_RANK_CONSTANT=10
RAG_MAX_NEW_TOKENS=1024

# Общая judge-модель RAGAS и DeepEval. Пусто — использовать RAG_GENERATION_MODEL.
RAGAS_JUDGE_MODEL=
RAGAS_THRESHOLD=0.7
RAGAS_MAX_TOKENS=2048
# Максимум одновременных judge-запросов Context Precision к vLLM.
RAGAS_CONTEXT_PRECISION_CONCURRENCY=5

# Сохраняются только факты Faithfulness и вопросы Answer Relevancy, не score метрик.
EVALUATION_ARTIFACT_CACHE_ENABLED=true
EVALUATION_ARTIFACT_CACHE_DIR=evaluation/artifact-cache
